<div class="pf2e-stores">

  <div class="pf2e-stores-toolbar">
    <button type="button" class="pf2e-settlement-btn" data-action="addStore">
      <i class="fa-solid fa-plus"></i> Add Store
    </button>
    <button type="button" class="pf2e-settlement-btn" data-action="rerollAllStores"
            title="Replace all stores with a new AI-generated set">
      <i class="fa-solid fa-dice"></i> Re-roll All Stores
    </button>
    {{#if closedStoreCount}}
      <button type="button" class="pf2e-settlement-btn{{#if showClosed}} is-active{{/if}}"
              data-action="toggleShowClosed">
        <i class="fa-solid fa-store-slash"></i>
        {{#if showClosed}}Hide{{else}}Show{{/if}} Closed ({{closedStoreCount}})
      </button>
    {{/if}}
    <button type="button" class="pf2e-settlement-btn{{#if compactStores}} is-active{{/if}}"
            data-action="toggleCompactStores" title="Toggle compact one-line store cards">
      <i class="fa-solid fa-list"></i>
      {{#if compactStores}}Expand{{else}}Compact{{/if}}
    </button>
    {{#if districts.length}}
      <select data-district-filter class="pf2e-district-filter-select" title="Filter stores by district">
        <option value="">— All districts —</option>
        {{#each districts}}
          <option value="{{id}}" {{#if (eqStr id ../districtFilter)}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    {{/if}}
  </div>

  <div class="pf2e-districts-section">
    <div class="pf2e-districts-header">
      <span><i class="fa-solid fa-map-location-dot"></i> Districts</span>
      <button type="button" class="pf2e-icon-btn" data-action="addDistrict" title="Add district">
        <i class="fa-solid fa-plus"></i>
      </button>
    </div>
    {{#if districts.length}}
      <ul class="pf2e-districts-list">
        {{#each districts}}
          <li class="pf2e-district-row">
            <input type="text" data-settlement-path="districts.{{@index}}.name"
                   value="{{name}}" class="pf2e-district-name" placeholder="District name…" />
            <input type="text" data-settlement-path="districts.{{@index}}.descriptor"
                   value="{{descriptor}}" class="pf2e-district-descriptor" placeholder="descriptor…" />
            <button type="button" class="pf2e-icon-btn pf2e-icon-btn--danger"
                    data-action="removeDistrict" data-district-id="{{id}}" title="Remove district">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </li>
        {{/each}}
      </ul>
    {{/if}}
  </div>

  {{#if storeTabs.length}}
    <nav class="pf2e-store-tabs">
      {{#each storeTabs}}
        <button type="button"
                class="pf2e-store-tab{{#if isActive}} is-active{{/if}}"
                data-action="switchStoreTab" data-store-tab="{{type}}">
          {{label}} <span class="pf2e-store-tab-count">{{count}}</span>
        </button>
      {{/each}}
    </nav>

    {{#each storeTabs}}
      {{#if isActive}}
        {{#each stores}}

          {{#if ../../compactStores}}

            <article class="pf2e-store-card pf2e-store-card--compact{{#if closed}} is-closed{{/if}}" data-store-id="{{id}}">
              <div class="pf2e-store-compact-row">
                {{#if closed}}
                  <span class="pf2e-closed-badge"><i class="fa-solid fa-lock"></i></span>
                {{/if}}
                {{#if isBlackMarket}}
                  <span class="pf2e-blackmarket-badge"><i class="fa-solid fa-skull"></i></span>
                {{/if}}
                <input type="text" data-settlement-path="stores.{{_globalIndex}}.name"
                       value="{{name}}" class="pf2e-store-name-input" />
                <span class="pf2e-store-type-pill">{{type}}</span>
                <span class="pf2e-store-tier-pill pf2e-store-tier--{{priceTier}}">{{priceTier}}</span>
                <span class="pf2e-store-compact-owner">{{owner.name}}</span>
                {{#if ../../showIncome}}
                  <span class="pf2e-store-compact-balance">{{income.balance}} gp</span>
                {{/if}}
                <button type="button" class="pf2e-icon-btn pf2e-icon-btn--danger"
                        data-action="removeStore" data-store-id="{{id}}" title="Remove store">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            </article>

          {{else}}

            <article class="pf2e-store-card{{#if closed}} is-closed{{/if}}" data-store-id="{{id}}">

              <header class="pf2e-store-card-header">
                <div class="pf2e-store-card-name">
                  {{#if closed}}
                    <span class="pf2e-closed-badge"><i class="fa-solid fa-lock"></i> Bankrupt</span>
                  {{/if}}
                  {{#if isBlackMarket}}
                    <span class="pf2e-blackmarket-badge"><i class="fa-solid fa-skull"></i> Black Market</span>
                  {{/if}}
                  <input type="text" data-settlement-path="stores.{{_globalIndex}}.name"
                         value="{{name}}" class="pf2e-store-name-input" />
                  <select data-settlement-path="stores.{{_globalIndex}}.type" class="pf2e-store-type-select">
                    {{#each ../../storeTypeOptions}}
                      <option value="{{value}}" {{#if (eqStr value ../type)}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                  <select data-settlement-path="stores.{{_globalIndex}}.priceTier" class="pf2e-store-tier-select">
                    {{#each ../../priceTierOptions}}
                      <option value="{{value}}" {{#if (eqStr value ../priceTier)}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                  <select data-settlement-path="stores.{{_globalIndex}}.districtId"
                          data-nullable-str class="pf2e-store-district-select"
                          title="Assign to district">
                    <option value="">— No district —</option>
                    {{#each ../../districts}}
                      <option value="{{id}}" {{#if (eqStr id ../districtId)}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                  <label class="pf2e-store-blackmarket-label" title="Hidden from players; attracts unrest">
                    <input type="checkbox" data-settlement-path="stores.{{_globalIndex}}.isBlackMarket"
                           {{#if isBlackMarket}}checked{{/if}} />
                    <i class="fa-solid fa-skull"></i>
                  </label>
                </div>
                <div class="pf2e-store-card-actions">
                  {{#if closed}}
                    <button type="button" class="pf2e-settlement-btn"
                            data-action="reopenStore" data-store-id="{{id}}" title="Reopen this store">
                      <i class="fa-solid fa-door-open"></i> Reopen
                    </button>
                  {{/if}}
                  <button type="button" class="pf2e-icon-btn"
                          data-action="rerollStore" data-store-id="{{id}}" title="Re-roll this store">
                    <i class="fa-solid fa-dice"></i>
                  </button>
                  <button type="button" class="pf2e-icon-btn pf2e-icon-btn--danger"
                          data-action="removeStore" data-store-id="{{id}}" title="Remove store">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </header>

              <div class="pf2e-store-grid">

                <section class="pf2e-store-info">
                  <div class="pf2e-store-owner">
                    <label>Owner</label>
                    <div class="pf2e-store-owner-row">
                      <input type="text" data-settlement-path="stores.{{_globalIndex}}.owner.name"
                             data-is-owner="true" value="{{owner.name}}"
                             title="Drop a PF2e actor here to link them as owner" />
                      {{#if ownerActor}}
                        <div class="pf2e-npc-chip">
                          {{#if ownerActor.portrait}}
                            <img src="{{ownerActor.portrait}}" class="pf2e-npc-chip-portrait" alt="{{ownerActor.name}}" />
                          {{/if}}
                          {{#if ownerActor.level}}
                            <span class="pf2e-npc-chip-level">Lv {{ownerActor.level}}</span>
                          {{/if}}
                          <button type="button" class="pf2e-icon-btn"
                                  data-action="openLinkedActor" data-actor-id="{{owner.actorId}}" title="Open actor sheet">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i>
                          </button>
                          <button type="button" class="pf2e-icon-btn"
                                  data-action="levelUpActor" data-actor-id="{{owner.actorId}}" title="Level Up actor">
                            <i class="fa-solid fa-arrow-up"></i>
                          </button>
                        </div>
                      {{/if}}
                      <button type="button" class="pf2e-icon-btn"
                              data-action="generateShopkeeper"
                              data-store-id="{{id}}" data-staff-id="owner"
                              title="Generate NPC for owner (uses Pf2eNpcMaker if installed)">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                      </button>
                    </div>
                  </div>
                  <div class="pf2e-store-schedule">
                    <label>Weekly Schedule</label>
                    <table class="pf2e-schedule-grid">
                      <thead>
                        <tr>
                          <th>Day</th><th>Open</th><th>Close</th>
                          <th title="Closed all day"><i class="fa-solid fa-ban"></i></th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each hours.schedule}}
                          <tr class="pf2e-schedule-row{{#if closed}} pf2e-schedule-row--closed{{/if}}">
                            <td class="pf2e-schedule-day-label">{{dayLabel}}</td>
                            <td><input type="text"
                                  data-settlement-path="stores.{{../_globalIndex}}.hours.schedule.{{day}}.open"
                                  value="{{open}}" /></td>
                            <td><input type="text"
                                  data-settlement-path="stores.{{../_globalIndex}}.hours.schedule.{{day}}.close"
                                  value="{{close}}" /></td>
                            <td class="pf2e-schedule-closed-cell">
                              <input type="checkbox"
                                     data-settlement-path="stores.{{../_globalIndex}}.hours.schedule.{{day}}.closed"
                                     {{#if closed}}checked{{/if}} />
                            </td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                  {{#if ../../showIncome}}
                    <div class="pf2e-store-income">
                      <label>Income</label>
                      <div class="pf2e-store-income-row">
                        <span>Balance</span>
                        <input type="number" data-settlement-path="stores.{{_globalIndex}}.income.balance"  value="{{income.balance}}" />
                        <span>gp/day</span>
                        <input type="number" data-settlement-path="stores.{{_globalIndex}}.income.dailyAvg" value="{{income.dailyAvg}}" />
                        {{#if income.daysInDebt}}
                          <span class="pf2e-debt-counter" title="Days continuously in debt">
                            <i class="fa-solid fa-triangle-exclamation"></i> {{income.daysInDebt}}d
                          </span>
                        {{/if}}
                      </div>
                    </div>
                  {{/if}}
                  <div class="pf2e-store-market-day">
                    <label>Market Day</label>
                    <select data-settlement-path="stores.{{_globalIndex}}.marketWeekday"
                            data-nullable-int
                            class="pf2e-store-market-select"
                            title="Income doubles on this weekday">
                      <option value="">— None —</option>
                      {{#each ../../weekdayOptions}}
                        <option value="{{value}}" {{#if (eqStr value ../marketWeekday)}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </div>
                </section>

                <section class="pf2e-store-staff">
                  <header>
                    <h4>Staff</h4>
                    <button type="button" class="pf2e-icon-btn"
                            data-action="addStaff" data-store-id="{{id}}" title="Add staff">
                      <i class="fa-solid fa-user-plus"></i>
                    </button>
                  </header>
                  {{#if staff.length}}
                    <ul class="pf2e-staff-list">
                      {{#each staff}}
                        <li class="pf2e-staff-row">
                          <input type="text" class="pf2e-staff-name"
                                 data-settlement-path="stores.{{../_globalIndex}}.staff.{{@index}}.name"
                                 data-staff-id="{{id}}"
                                 value="{{name}}"
                                 title="Drop a PF2e actor here to link them" />
                          <input type="text" class="pf2e-staff-role"
                                 data-settlement-path="stores.{{../_globalIndex}}.staff.{{@index}}.role"
                                 value="{{role}}" />
                          <select class="pf2e-staff-shift pf2e-staff-shift--{{shift}}"
                                  data-settlement-path="stores.{{../_globalIndex}}.staff.{{@index}}.shift">
                            {{#each ../../../shiftOptions}}
                              <option value="{{value}}" {{#if (eqStr value ../../shift)}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                          </select>
                          {{#if resolvedActor}}
                            <div class="pf2e-npc-chip pf2e-npc-chip--inline">
                              {{#if resolvedActor.portrait}}
                                <img src="{{resolvedActor.portrait}}" class="pf2e-npc-chip-portrait" alt="{{resolvedActor.name}}" />
                              {{/if}}
                              {{#if resolvedActor.level}}
                                <span class="pf2e-npc-chip-level">{{resolvedActor.level}}</span>
                              {{/if}}
                              <button type="button" class="pf2e-icon-btn"
                                      data-action="openLinkedActor" data-actor-id="{{actorId}}" title="Open actor sheet">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                              </button>
                              <button type="button" class="pf2e-icon-btn"
                                      data-action="levelUpActor" data-actor-id="{{actorId}}" title="Level Up actor">
                                <i class="fa-solid fa-arrow-up"></i>
                              </button>
                            </div>
                          {{/if}}
                          <button type="button" class="pf2e-icon-btn"
                                  data-action="generateShopkeeper"
                                  data-store-id="{{@../id}}" data-staff-id="{{id}}"
                                  title="Generate NPC for this worker">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                          </button>
                          <button type="button" class="pf2e-icon-btn pf2e-icon-btn--danger"
                                  data-action="removeStaff"
                                  data-store-id="{{@../id}}" data-staff-id="{{id}}" title="Remove">
                            <i class="fa-solid fa-xmark"></i>
                          </button>
                        </li>
                      {{/each}}
                    </ul>
                  {{else}}
                    <em class="pf2e-empty">No staff listed.</em>
                  {{/if}}
                </section>

                <section class="pf2e-store-inventory" data-inventory-drop="true" title="Drop a PF2e item here to add it to inventory">
                  <header>
                    <h4>Inventory</h4>
                    <button type="button" class="pf2e-icon-btn"
                            data-action="generateStoreItem" data-store-id="{{id}}" data-item-type="equipment"
                            title="Generate item (uses Pf2eItemGenerator if installed)">
                      <i class="fa-solid fa-flask"></i>
                    </button>
                  </header>
                  {{#if inventory.length}}
                    <table class="pf2e-inventory-table">
                      <thead>
                        <tr>
                          <th>Item</th><th>Stock</th><th>Price (gp)</th>
                          {{#if (neqNum effectiveMul 1)}}
                            <th title="Base price × tier × settlement multiplier">Effective (gp)</th>
                          {{/if}}
                        </tr>
                      </thead>
                      <tbody>
                        {{#each inventory}}
                          <tr>
                            <td><input type="text"   data-settlement-path="stores.{{../_globalIndex}}.inventory.{{@index}}.name"  value="{{name}}" /></td>
                            <td><input type="number" data-settlement-path="stores.{{../_globalIndex}}.inventory.{{@index}}.stock" value="{{stock}}" /></td>
                            <td><input type="number" data-settlement-path="stores.{{../_globalIndex}}.inventory.{{@index}}.price" value="{{price}}" /></td>
                            {{#if (neqNum ../effectiveMul 1)}}
                              <td class="pf2e-effective-price">{{mulNum price ../effectiveMul}}</td>
                            {{/if}}
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  {{else}}
                    <em class="pf2e-empty">Empty shelves — generate an item above or drop one from the Items sidebar.</em>
                  {{/if}}
                </section>

              </div>

            </article>

          {{/if}}

        {{/each}}
      {{/if}}
    {{/each}}

  {{else}}
    <div class="pf2e-empty-state">
      <i class="fa-solid fa-store-slash"></i>
      <p>No stores yet — click <em>Add Store</em> above.</p>
    </div>
  {{/if}}
</div>
