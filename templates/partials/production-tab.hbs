<div class="pf2e-production">

  <h4><i class="fa-solid fa-wheat-awn"></i> Production goods</h4>
  {{#if settlement.production.length}}
    <div class="pf2e-production-tags">
      {{#each settlement.production}}
        <span class="pf2e-production-tag">{{this}}</span>
      {{/each}}
    </div>
  {{else}}
    <em class="pf2e-empty">No goods recorded yet.</em>
  {{/if}}

  {{#if tradeGoods.length}}
    <h4><i class="fa-solid fa-book-open"></i> Trade Goods Catalogue</h4>
    <table class="pf2e-trade-goods-table">
      <thead>
        <tr>
          <th>Good</th>
          <th>Base (gp)</th>
          {{#if (neqNum priceMultiplier 1)}}
            <th title="Base price × price multiplier">Effective (gp)</th>
          {{/if}}
        </tr>
      </thead>
      <tbody>
        {{#each tradeGoods}}
          <tr>
            <td>{{name}}</td>
            <td>{{priceGp}}</td>
            {{#if (neqNum ../priceMultiplier 1)}}
              <td class="pf2e-effective-price">{{effectivePrice}}</td>
            {{/if}}
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{/if}}

  <h4><i class="fa-solid fa-route"></i> Trade Routes</h4>
  {{#if settlement.tradeRoutes.length}}
    <table class="pf2e-trade-routes-table">
      <thead>
        <tr><th>Partner</th><th>Goods</th><th>GP / Week</th><th></th></tr>
      </thead>
      <tbody>
        {{#each settlement.tradeRoutes}}
          <tr>
            <td>
              <select data-settlement-path="tradeRoutes.{{@index}}.partnerId"
                      style="width:100%;padding:0.2em;border:1px solid #c2a070;background:#fffbef;border-radius:3px;">
                <option value="">— none —</option>
                {{#each ../settlementJournals}}
                  <option value="{{id}}"{{#if (eqStr id ../../partnerId)}} selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <input type="text" data-settlement-path="tradeRoutes.{{@index}}.goods"
                     value="{{goods}}" placeholder="grain, iron…"
                     style="width:100%;padding:0.2em;border:1px solid #c2a070;background:#fffbef;border-radius:3px;" />
            </td>
            <td>
              <input type="number" min="0" data-settlement-path="tradeRoutes.{{@index}}.gpPerWeek"
                     value="{{gpPerWeek}}"
                     style="width:5em;padding:0.2em;border:1px solid #c2a070;background:#fffbef;border-radius:3px;" />
            </td>
            <td>
              <button type="button" class="pf2e-icon-btn pf2e-icon-btn--danger"
                      data-action="removeTradeRoute" data-index="{{@index}}">
                <i class="fa-solid fa-trash"></i>
              </button>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <em class="pf2e-empty">No trade routes established.</em>
  {{/if}}
  <button type="button" class="pf2e-settlement-btn" data-action="addTradeRoute"
          style="margin-top:0.4em;"><i class="fa-solid fa-plus"></i> Add Route</button>

  <h4><i class="fa-solid fa-coins"></i> Treasury (live)</h4>
  <table class="pf2e-treasury-table">
    <tbody>
      <tr><th>CP</th><td>{{settlement.treasury.cp}}</td></tr>
      <tr><th>SP</th><td>{{settlement.treasury.sp}}</td></tr>
      <tr><th>GP</th><td>{{settlement.treasury.gp}}</td></tr>
      <tr><th>PP</th><td>{{settlement.treasury.pp}}</td></tr>
    </tbody>
  </table>

  <h4><i class="fa-solid fa-store"></i> Store balances</h4>
  {{#if settlement.stores.length}}
    <table class="pf2e-store-balance-table">
      <thead><tr><th>Store</th><th>Type</th><th>Balance (gp)</th><th>Daily avg</th></tr></thead>
      <tbody>
        {{#each settlement.stores}}
          <tr>
            <td>{{name}}</td>
            <td>{{type}}</td>
            <td>{{income.balance}}</td>
            <td>{{income.dailyAvg}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <em class="pf2e-empty">No stores to balance.</em>
  {{/if}}
</div>
